# .NET Clean Architecture — .gitignore

# Build output
bin/
obj/

# SQLite database files
*.db
*.db-shm
*.db-wal

# EF Core migrations snapshots (keep migrations, exclude DB files)
*.sqlite

# Visual Studio
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# Rider / JetBrains
.idea/
*.DotSettings.user

# VS Code
.vscode/

# User secrets
secrets.json
appsettings.Local.json

# NuGet
*.nupkg
.nuget/
packages/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/
